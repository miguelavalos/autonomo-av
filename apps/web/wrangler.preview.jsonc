{
  "$schema": "../../node_modules/wrangler/config-schema.json",
  "name": "autonomoav-web-preview",
  "compatibility_date": "2026-04-22",
  "workers_dev": false,
  "preview_urls": false,
  "observability": {
    "enabled": true
  },
  "vars": {
    "ENVIRONMENT": "preview"
  },
  "routes": [
    {
      "pattern": "autonomo-av-preview.avalsys.com",
      "custom_domain": true
    }
  ],
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application"
  }
}
